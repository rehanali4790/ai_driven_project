{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm install --prefer-offline && concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm install --prefer-offline && rimraf node_modules/.vite-temp && tsc -b && vite build",
    "build:prod": "pnpm install --prefer-offline && rimraf node_modules/.vite-temp && tsc -b && vite build --mode production",
    "lint": "pnpm install --prefer-offline && eslint .",
    "preview": "pnpm install --prefer-offline && vite preview",
    "start:server": "tsx server/index.ts",
    "parse:submission-pdf": "tsx server/scripts/parse-submission-pdf.ts",
    "install-deps": "pnpm install --prefer-offline",
    "clean": "rimraf node_modules .pnpm-store pnpm-lock.yaml dist"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
